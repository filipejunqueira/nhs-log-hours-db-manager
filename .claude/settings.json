{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm create *)",
      "Bash(npm install)",
      "Bash(npm ci)",
      "Bash(npm run *)",
      "Bash(npx vite *)"
    ],
    "deny": [
      "Edit(engine_v2/**)",
      "Write(engine_v2/**)"
    ]
  }
}
